// ── SECTION 1: DEADLINES ────────────────────────────
const DEADLINES_KEY = 'mm_admin_deadlines';
let deadlineTab = 'upcoming';

const PRESET_DEADLINES = [
  { id:'d1', text:'Post apartment listing on Gens de Confiance', date:'2026-04-20', cat:'Rental', done:false },
  { id:'d2', text:'Current tenant leaving — organize état des lieux', date:'2026-05-11', cat:'Rental', done:false },
  { id:'d3', text:'ETH restaking due', date:'2026-04-25', cat:'Crypto', done:false },
  { id:'d4', text:'POL restaking due', date:'2026-05-06', cat:'Crypto', done:false },
  { id:'d5', text:'Health insurance expires — renew or find new via employer', date:'2026-05-30', cat:'Health', done:false },
  { id:'d6', text:'Income tax declaration (opens April, deadline ~June)', date:'2026-06-05', cat:'Tax', done:false },
  { id:'d7', text:'Contact Italian consulate to renew expired passport', date:'2026-04-25', cat:'Admin', done:false },
  { id:'d8', text:'Pay accountant', date:'2026-05-15', cat:'Finance', done:false },
  { id:'d9', text:'November apartment charges (syndic)', date:'2026-11-01', cat:'Property', done:false },
  { id:'d10', text:'Home insurance annual review', date:'2026-10-15', cat:'Insurance', done:false },
];

function loadDeadlines() {
  if (!localStorage.getItem(DEADLINES_KEY)) {
    localStorage.setItem(DEADLINES_KEY, JSON.stringify(PRESET_DEADLINES));
  }
  return JSON.parse(localStorage.getItem(DEADLINES_KEY));
}

function saveDeadlines(dl) { localStorage.setItem(DEADLINES_KEY, JSON.stringify(dl)); }

function daysUntil(dateStr) {
  const d = new Date(dateStr + 'T00:00:00');
  const now = new Date(); now.setHours(0,0,0,0);
  return Math.round((d - now) / 86400000);
}

function urgencyClass(days) {
  if (days < 0) return 'urgent';
  if (days <= 7) return 'urgent';
  if (days <= 30) return 'soon';
  return 'ok';
}

function urgencyLabel(days) {
  if (days < 0) return `${Math.abs(days)}d overdue`;
  if (days === 0) return 'Today';
  if (days === 1) return 'Tomorrow';
  return `${days} days`;
}

function switchDeadlineTab(tab) {
  deadlineTab = tab;
  document.getElementById('dtab-upcoming').classList.toggle('active', tab === 'upcoming');
  document.getElementById('dtab-done').classList.toggle('active', tab === 'done');
  renderDeadlines();
}

function renderDeadlines() {
  const dl = loadDeadlines();
  const filtered = dl.filter(d => deadlineTab === 'upcoming' ? !d.done : d.done);
  const sorted = filtered.sort((a,b) => new Date(a.date) - new Date(b.date));
  const el = document.getElementById('deadline-list');
  const urgent = dl.filter(d => !d.done && daysUntil(d.date) <= 7).length;
  const badge = document.getElementById('deadline-badge');
  badge.textContent = urgent > 0 ? urgent : '';
  badge.style.display = urgent > 0 ? 'inline' : 'none';

  if (!sorted.length) {
    el.innerHTML = `<div class="empty-note">${deadlineTab === 'done' ? 'Nothing completed yet.' : 'All clear! 🎉'}</div>`;
    return;
  }
  el.innerHTML = sorted.map(d => {
    const days = daysUntil(d.date);
    const urg = urgencyClass(days);
    const label = urgencyLabel(days);
    return `<div class="deadline-item">
      <div class="deadline-dot ${d.done ? 'done' : urg}"></div>
      <div class="deadline-info">
        <div class="deadline-title ${d.done ? 'done' : ''}">${d.text}</div>
        <div class="deadline-meta">
          <span class="deadline-date">${d.date}${d.cat ? ' · ' + d.cat : ''}</span>
          ${!d.done ? `<span class="deadline-urgency urgency-${urg}">${label}</span>` : ''}
        </div>
      </div>
      <div class="deadline-actions">
        ${!d.done && days <= 0 ? `<button class="deadline-push-btn" onclick="pushDeadlineToHome('${d.id}')">→ Home</button>` : ''}
        ${!d.done ? `<button class="deadline-done-btn" onclick="markDeadlineDone('${d.id}')">✓</button>` : ''}
      </div>
    </div>`;
  }).join('');
}

function addDeadline() {
  const text = document.getElementById('deadline-text').value.trim();
  const date = document.getElementById('deadline-date').value || TODAY_STR;
  const cat = document.getElementById('deadline-cat').value.trim();
  if (!text) return;
  const dl = loadDeadlines();
  dl.push({ id: 'u' + Date.now(), text, date, cat, done: false });
  saveDeadlines(dl); renderDeadlines();
  document.getElementById('deadline-text').value = '';
  document.getElementById('deadline-cat').value = '';
}

function markDeadlineDone(id) {
  const dl = loadDeadlines();
  const item = dl.find(d => d.id === id);
  if (item) item.done = true;
  saveDeadlines(dl); renderDeadlines();
}

function pushDeadlineToHome(id) {
  const dl = loadDeadlines();
  const item = dl.find(d => d.id === id);
  if (!item) return;
  const tasks = JSON.parse(localStorage.getItem('mm_tasks') || '[]');
  tasks.push({ text: item.text, done: false, date: item.date });
  localStorage.setItem('mm_tasks', JSON.stringify(tasks));
  const btn = event.target;
  btn.textContent = '✓ Added';
  btn.style.background = 'var(--accent-glow)';
  setTimeout(() => { btn.textContent = '→ Home'; btn.style.background = ''; }, 2000);
}

// Daily auto-push: check each morning if any deadlines are due today
function autoPushDueToday() {
  const lastPush = localStorage.getItem('mm_deadline_push_date');
  if (lastPush === TODAY_STR) return;
  const dl = loadDeadlines();
  const tasks = JSON.parse(localStorage.getItem('mm_tasks') || '[]');
  let pushed = false;
  dl.forEach(d => {
    if (!d.done && d.date === TODAY_STR) {
      const alreadyThere = tasks.find(t => t.text === d.text);
      if (!alreadyThere) { tasks.push({ text: d.text, done: false, date: d.date }); pushed = true; }
    }
  });
  if (pushed) { localStorage.setItem('mm_tasks', JSON.stringify(tasks)); localStorage.setItem('mm_deadline_push_date', TODAY_STR); }
}

// ── SECTION 2: EMAIL TRIAGE ─────────────────────────
async function triageEmails() {
  const content = document.getElementById('email-paste').value.trim();
  if (!content) return;
  const btn = document.getElementById('triage-btn');
  btn.disabled = true; btn.textContent = 'Triaging...';
  document.getElementById('email-results').innerHTML = '<div class="shimmer"></div><div class="shimmer"></div><div class="shimmer"></div>';
  try {
    const r = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514', max_tokens: 1000,
        system: 'You are an intelligent email triage assistant. Respond ONLY with valid JSON. No markdown, no preamble.',
        messages: [{ role: 'user', content: `Triage these emails. For each, classify as: ACTION_REQUIRED, REPLY_NEEDED, UNSUBSCRIBE, or FYI_ONLY.
For ACTION_REQUIRED and REPLY_NEEDED, write a short draft response in French or English matching the email language.
For UNSUBSCRIBE, write a short unsubscribe request.

Return JSON array:
[{"tag":"ACTION_REQUIRED","from":"sender","subject":"subject","summary":"what this is about","draft":"suggested response or action"}]

Emails:
${content}` }]
      })
    });
    const d = await r.json();
    const text = d.content?.find(b => b.type === 'text')?.text || '[]';
    const items = JSON.parse(text.replace(/```json|```/g,'').trim());
    renderEmailResults(items);
  } catch(e) {
    document.getElementById('email-results').innerHTML = '<div class="empty-note">Triage failed. Check your connection.</div>';
  }
  btn.disabled = false; btn.textContent = '⚡ Triage with Claude';
}

function renderEmailResults(items) {
  if (!items.length) { document.getElementById('email-results').innerHTML = '<div class="empty-note">No actionable emails found.</div>'; return; }
  const tagLabels = { ACTION_REQUIRED:'action', REPLY_NEEDED:'reply', UNSUBSCRIBE:'unsub', FYI_ONLY:'fyi' };
  document.getElementById('email-results').innerHTML = `<div class="email-result">${items.map((item,i) => `
    <div class="email-card">
      <span class="email-tag tag-${tagLabels[item.tag]||'fyi'}">${item.tag?.replace('_',' ')}</span>
      <div class="email-subject">${item.subject||'No subject'}</div>
      <div class="email-from">From: ${item.from||'Unknown'}</div>
      <div class="email-summary">${item.summary||''}</div>
      ${item.draft ? `<div class="email-draft">${item.draft}</div>` : ''}
      <div class="email-actions">
        ${item.draft ? `<button class="email-action-btn primary" onclick="copyDraft(${i})">Copy draft</button>` : ''}
        ${item.tag === 'ACTION_REQUIRED' ? `<button class="email-action-btn" onclick="addEmailTask('${item.subject?.replace(/'/g,"\\'")}')">→ Add to tasks</button>` : ''}
      </div>
    </div>`).join('')}</div>`;
  window._emailItems = items;
}

function copyDraft(i) {
  const item = window._emailItems?.[i];
  if (!item?.draft) return;
  navigator.clipboard?.writeText(item.draft).catch(() => {});
  event.target.textContent = '✓ Copied';
  setTimeout(() => event.target.textContent = 'Copy draft', 2000);
}

function addEmailTask(subject) {
  const tasks = JSON.parse(localStorage.getItem('mm_tasks') || '[]');
  tasks.push({ text: `Email: ${subject}`, done: false, date: TODAY_STR });
  localStorage.setItem('mm_tasks', JSON.stringify(tasks));
  event.target.textContent = '✓ Added';
  setTimeout(() => event.target.textContent = '→ Add to tasks', 2000);
}

