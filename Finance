// Investment strategy from JSONBin
async function loadInvestmentStrategy(force=false) {
  const cached = localStorage.getItem('mm_strategy');
  const cachedDate = localStorage.getItem('mm_strategy_date');
  const monthKey = new Date().toISOString().slice(0,7);
  if (cached && cachedDate === monthKey && !force) { renderStrategy(cached); return; }

  const binId = localStorage.getItem('mm_jsonbin_strategy_id');
  const binKey = localStorage.getItem('mm_jsonbin_strategy_key');
  if (!binId || !binKey) {
    document.getElementById('investment-content').innerHTML = `<div class="empty-note">Enter your JSONBin config below to connect your investment strategy.</div>`;
    return;
  }

  document.getElementById('investment-content').innerHTML = '<div class="shimmer"></div><div class="shimmer"></div>';
  document.getElementById('strategy-refresh').classList.add('spinning');
  try {
    const r = await fetch(`https://api.jsonbin.io/v3/b/${binId}/latest`, { headers:{ 'X-Master-Key': binKey }});
    const d = await r.json();
    const content = d?.record?.content || d?.record?.strategy || JSON.stringify(d?.record);
    localStorage.setItem('mm_strategy', content);
    localStorage.setItem('mm_strategy_date', monthKey);
    renderStrategy(content);
  } catch {
    document.getElementById('investment-content').innerHTML = '<div class="empty-note">Could not load strategy. Check JSONBin config.</div>';
  }
  document.getElementById('strategy-refresh').classList.remove('spinning');
}

function renderStrategy(content) {
  document.getElementById('investment-content').innerHTML = `<div class="investment-content">${content.replace(/\n/g,'<br/>')}</div>`;
}

function saveJsonbinConfig() {
  const id = document.getElementById('jsonbin-id').value.trim();
  const key = document.getElementById('jsonbin-key').value.trim();
  if (id) localStorage.setItem('mm_jsonbin_strategy_id', id);
  if (key) localStorage.setItem('mm_jsonbin_strategy_key', key);
  loadInvestmentStrategy(true);
}

