<script>
const TODAY = new Date();
const TODAY_STR = TODAY.toISOString().split('T')[0];

// ── TOGGLE ──────────────────────────────────────────
function toggle(id) {
  const col = document.getElementById(`col-${id}`);
  const chev = document.getElementById(`chev-${id}`);
