let pinBuffer = '';
let pinMode = 'unlock'; // 'unlock' | 'setup' | 'confirm' | 'change'
let pinSetupFirst = '';

function initPin() {
  const hasPin = !!localStorage.getItem('mm_vault_pin');
  if (!hasPin) {
    pinMode = 'setup';
    document.getElementById('pin-title').textContent = '🔐 Create your PIN';
    document.getElementById('pin-subtitle').textContent = 'Choose a 4-digit PIN to protect your documents';
    document.getElementById('pin-hint').textContent = 'You\'ll need to remember this.';
  }
}

function pinPress(digit) {
  if (pinBuffer.length >= 4) return;
  pinBuffer += digit;
  updatePinDisplay();
  if (pinBuffer.length === 4) setTimeout(() => processPinInput(), 200);
}

function pinDel() { pinBuffer = pinBuffer.slice(0,-1); updatePinDisplay(); }

function updatePinDisplay() {
  for (let i = 0; i < 4; i++) {
    document.getElementById(`pd${i}`).classList.toggle('filled', i < pinBuffer.length);
  }
}

function processPinInput() {
  const hasPin = localStorage.getItem('mm_vault_pin');
  if (pinMode === 'setup') {
    pinSetupFirst = pinBuffer; pinBuffer = '';
    pinMode = 'confirm';
    document.getElementById('pin-title').textContent = 'Confirm your PIN';
    document.getElementById('pin-subtitle').textContent = 'Enter the same PIN again to confirm';
    updatePinDisplay();
  } else if (pinMode === 'confirm') {
    if (pinBuffer === pinSetupFirst) {
      localStorage.setItem('mm_vault_pin', hashPin(pinBuffer));
      pinBuffer = ''; pinMode = 'unlock';
      openVault();
    } else {
      showPinError('PINs don\'t match. Try again.');
      pinBuffer = ''; pinSetupFirst = ''; pinMode = 'setup';
      document.getElementById('pin-title').textContent = '🔐 Create your PIN';
      document.getElementById('pin-subtitle').textContent = 'Choose a 4-digit PIN to protect your documents';
      updatePinDisplay();
    }
  } else {
    if (hashPin(pinBuffer) === localStorage.getItem('mm_vault_pin')) {
      pinBuffer = ''; openVault();
    } else {
      showPinError('Incorrect PIN. Try again.');
      pinBuffer = ''; updatePinDisplay();
    }
  }
}

function hashPin(pin) {
  let h = 0;
  for (let i = 0; i < pin.length; i++) { h = ((h << 5) - h) + pin.charCodeAt(i); h |= 0; }
  return h.toString(36);
}

function showPinError(msg) {
  const el = document.getElementById('pin-error');
  el.textContent = msg;
  setTimeout(() => el.textContent = '', 2500);
}

function openVault() {
  document.getElementById('vault-gate').style.display = 'none';
  document.getElementById('vault-content').style.display = 'block';
  renderVaultDocs();
}

function lockVault() {
  document.getElementById('vault-gate').style.display = 'block';
  document.getElementById('vault-content').style.display = 'none';
  pinBuffer = ''; updatePinDisplay();
  document.getElementById('pin-title').textContent = '🔐 Vault locked';
  document.getElementById('pin-subtitle').textContent = 'Enter your 4-digit PIN to access your documents';
  pinMode = 'unlock';
}

function changePinMode() {
  lockVault();
  pinMode = 'setup';
  document.getElementById('pin-title').textContent = '🔐 Change PIN';
  document.getElementById('pin-subtitle').textContent = 'Choose a new 4-digit PIN';
}

