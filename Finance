function renderBudget() {
  const budget = loadBudget();
  document.getElementById('budget-items').innerHTML = budget.map((b, i) => {
    const pct = b.target > 0 ? Math.min(100, Math.round((b.actual / b.target) * 100)) : 0;
    const fillClass = pct > 100 ? 'fill-over' : pct > 80 ? 'fill-warn' : 'fill-ok';
    return `<div class="budget-item">
      <div class="budget-header">
        <span class="budget-cat">${b.cat}</span>
        <span class="budget-amounts" onclick="editBudgetItem(${i})" style="cursor:pointer">
          €${b.actual} / <strong>€${b.target}</strong>
        </span>
      </div>
      <div class="budget-bar-bg">
        <div class="budget-bar-fill ${fillClass}" style="width:${pct}%"></div>
      </div>
    </div>`;
  }).join('');
}

function editBudgetItem(i) {
  const budget = loadBudget();
  const b = budget[i];
  const newTarget = prompt(`Budget target for ${b.cat} (€)?`, b.target);
  const newActual = prompt(`Actual spent this month for ${b.cat} (€)?`, b.actual);
  if (newTarget !== null) b.target = parseFloat(newTarget) || 0;
  if (newActual !== null) b.actual = parseFloat(newActual) || 0;
  localStorage.setItem('mm_budget', JSON.stringify(budget));
  renderBudget();
}

function resetBudget() {
  if (!confirm('Reset all actual spending to 0?')) return;
  const budget = loadBudget();
  budget.forEach(b => b.actual = 0);
  localStorage.setItem('mm_budget', JSON.stringify(budget));
  renderBudget();
}

