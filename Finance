<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="theme-color" content="#ffffff"/>
<title>MON MONDE — Admin & Finance</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg: #f5f5f0; --surface: #ffffff; --surface2: #f0efea; --surface3: #e8e7e1;
  --border: rgba(0,0,0,0.07); --border-strong: rgba(0,0,0,0.13);
  --accent: #3a9463; --accent-light: #5CDB95; --accent-glow: rgba(92,219,149,0.1);
  --red: #e05252; --red-glow: rgba(224,82,82,0.1);
  --amber: #e0a352; --amber-glow: rgba(224,163,82,0.1);
  --text: #1a1a1a; --text-mid: #555; --text-dim: #999;
  --shadow: 0 2px 12px rgba(0,0,0,0.06); --radius: 12px;
}
* { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
body { font-family:'DM Sans',sans-serif; font-weight:400; background:var(--bg); color:var(--text); min-height:100dvh; overflow-x:hidden; }
.app { max-width:430px; margin:0 auto; padding-bottom:52px; }

/* HEADER */
.header { padding:52px 20px 16px; background:var(--surface); border-bottom:1px solid var(--border); display:flex; align-items:center; gap:14px; }
.back-btn { width:36px; height:36px; background:var(--surface2); border:1px solid var(--border); border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:16px; color:var(--text-mid); text-decoration:none; flex-shrink:0; }
.header-text { flex:1; }
.header-eyebrow { font-size:10px; font-weight:500; letter-spacing:0.25em; text-transform:uppercase; color:var(--accent); margin-bottom:2px; }
.header-title { font-family:'Syne',sans-serif; font-weight:800; font-size:22px; color:var(--text); letter-spacing:-0.01em; }

/* SECTIONS */
.sections { padding:16px 16px 0; display:flex; flex-direction:column; gap:12px; }

/* CARD */
.card { background:var(--surface); border:1px solid var(--border); border-radius:var(--radius); box-shadow:var(--shadow); overflow:hidden; }
.card-header { display:flex; align-items:center; justify-content:space-between; padding:14px 16px; cursor:pointer; user-select:none; transition:background 0.15s; border-bottom:1px solid var(--border); }
.card-header:active { background:var(--surface2); }
.card-header-left { display:flex; align-items:center; gap:10px; }
.card-icon { width:28px; height:28px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:14px; background:var(--accent-glow); flex-shrink:0; }
.card-title { font-size:13px; font-weight:600; color:var(--text); }
.card-badge { font-size:10px; font-weight:600; padding:2px 7px; border-radius:20px; background:var(--red-glow); color:var(--red); margin-left:6px; }
.card-chevron { font-size:11px; color:var(--text-dim); transition:transform 0.3s; }
.card-chevron.open { transform:rotate(180deg); }
.card-collapse { overflow:hidden; max-height:0; transition:max-height 0.4s cubic-bezier(0.4,0,0.2,1); }
.card-collapse.open { max-height:3000px; }

/* SHARED BODY */
.card-body { padding:14px 16px 16px; }

/* LABELS */
.section-label { font-size:9px; font-weight:600; letter-spacing:0.22em; text-transform:uppercase; color:var(--accent); padding-bottom:8px; margin-bottom:10px; border-bottom:1px solid var(--border); }

/* ── SECTION 1: ADMIN TO-DO & DEADLINES ── */
.deadline-tabs { display:flex; border-bottom:1px solid var(--border); }
.deadline-tab { flex:1; padding:9px; font-size:11px; font-weight:600; color:var(--text-dim); background:none; border:none; cursor:pointer; border-bottom:2px solid transparent; transition:all 0.2s; margin-bottom:-1px; }
.deadline-tab.active { color:var(--accent); border-bottom-color:var(--accent); }

.deadline-list { padding:10px 16px 4px; }
.deadline-item { display:flex; align-items:flex-start; gap:10px; padding:10px 0; border-bottom:1px solid var(--border); }
.deadline-item:last-child { border-bottom:none; }
.deadline-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; margin-top:5px; }
.deadline-dot.urgent { background:var(--red); }
.deadline-dot.soon { background:var(--amber); }
.deadline-dot.ok { background:var(--accent); }
.deadline-dot.done { background:var(--text-dim); }
.deadline-info { flex:1; }
.deadline-title { font-size:13px; font-weight:500; color:var(--text); line-height:1.3; }
.deadline-title.done { opacity:0.4; text-decoration:line-through; }
.deadline-meta { display:flex; align-items:center; gap:8px; margin-top:3px; flex-wrap:wrap; }
.deadline-date { font-size:11px; color:var(--text-dim); }
.deadline-urgency { font-size:10px; font-weight:600; padding:1px 6px; border-radius:20px; }
.urgency-urgent { background:var(--red-glow); color:var(--red); }
.urgency-soon { background:var(--amber-glow); color:var(--amber); }
.urgency-ok { background:var(--accent-glow); color:var(--accent); }
.deadline-actions { display:flex; gap:6px; align-items:center; flex-shrink:0; }
.deadline-push-btn { font-size:10px; font-weight:600; color:var(--accent); background:var(--accent-glow); border:none; border-radius:6px; padding:3px 8px; cursor:pointer; white-space:nowrap; }
.deadline-done-btn { font-size:10px; color:var(--text-dim); background:var(--surface2); border:1px solid var(--border); border-radius:6px; padding:3px 8px; cursor:pointer; }

.deadline-add-form { padding:10px 16px 14px; border-top:1px solid var(--border); display:flex; flex-direction:column; gap:8px; }
.deadline-input-row { display:flex; gap:8px; }
.deadline-input { flex:1; background:var(--surface2); border:1px solid var(--border); border-radius:8px; padding:9px 12px; font-family:'DM Sans',sans-serif; font-size:13px; color:var(--text); outline:none; }
.deadline-input:focus { border-color:var(--accent); }
.deadline-input::placeholder { color:var(--text-dim); }
.deadline-date-row { display:flex; gap:8px; }
.deadline-date-input { flex:1; background:var(--surface2); border:1px solid var(--border); border-radius:8px; padding:8px 12px; font-family:'DM Sans',sans-serif; font-size:12px; color:var(--text-mid); outline:none; }
.deadline-add-btn { width:36px; height:36px; background:var(--accent); border:none; border-radius:8px; color:#fff; font-size:22px; cursor:pointer; display:flex; align-items:center; justify-content:center; font-weight:300; flex-shrink:0; }

/* ── SECTION 2: EMAIL TRIAGE ── */
.email-paste-area { width:100%; min-height:90px; background:var(--surface2); border:1px solid var(--border); border-radius:8px; padding:12px; font-family:'DM Sans',sans-serif; font-size:13px; color:var(--text); outline:none; resize:vertical; line-height:1.5; }
.email-paste-area:focus { border-color:var(--accent); }
.email-paste-area::placeholder { color:var(--text-dim); font-style:italic; }
.email-triage-btn { width:100%; margin-top:10px; padding:12px; background:var(--accent); border:none; border-radius:8px; font-family:'DM Sans',sans-serif; font-size:13px; font-weight:600; color:#fff; cursor:pointer; transition:opacity 0.2s; }
.email-triage-btn:hover { opacity:0.88; }
.email-triage-btn:disabled { opacity:0.5; cursor:not-allowed; }
.email-result { margin-top:12px; display:flex; flex-direction:column; gap:8px; }
.email-card { background:var(--surface2); border:1px solid var(--border); border-radius:10px; padding:12px; }
.email-tag { display:inline-block; font-size:9px; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; padding:2px 7px; border-radius:20px; margin-bottom:7px; }
.tag-action { background:var(--red-glow); color:var(--red); }
.tag-reply { background:var(--amber-glow); color:var(--amber); }
.tag-unsub { background:rgba(0,0,0,0.06); color:var(--text-mid); }
.tag-fyi { background:var(--accent-glow); color:var(--accent); }
.email-subject { font-size:13px; font-weight:600; color:var(--text); margin-bottom:4px; }
.email-from { font-size:11px; color:var(--text-dim); margin-bottom:6px; }
.email-summary { font-size:12px; color:var(--text-mid); line-height:1.6; margin-bottom:8px; }
.email-draft { background:var(--surface); border:1px solid var(--border); border-radius:8px; padding:10px; font-size:12px; color:var(--text-mid); line-height:1.65; margin-bottom:8px; font-style:italic; }
.email-actions { display:flex; gap:8px; flex-wrap:wrap; }
.email-action-btn { font-size:11px; font-weight:600; padding:5px 12px; border-radius:8px; cursor:pointer; border:1px solid var(--border); background:var(--surface); color:var(--text-mid); transition:all 0.2s; }
.email-action-btn.primary { background:var(--accent); color:#fff; border-color:var(--accent); }

/* ── SECTION 3: FINANCE DASHBOARD ── */
.finance-tabs { display:flex; border-bottom:1px solid var(--border); }
.finance-tab { flex:1; padding:10px 6px; font-size:10px; font-weight:600; letter-spacing:0.06em; text-transform:uppercase; color:var(--text-dim); background:none; border:none; cursor:pointer; border-bottom:2px solid transparent; transition:all 0.2s; margin-bottom:-1px; }
.finance-tab.active { color:var(--accent); border-bottom-color:var(--accent); }
.finance-panel { display:none; padding:14px 16px 16px; }
.finance-panel.active { display:block; }

/* Overview */
.balance-hero { text-align:center; padding:12px 0 16px; border-bottom:1px solid var(--border); margin-bottom:14px; }
.balance-label { font-size:10px; font-weight:500; letter-spacing:0.2em; text-transform:uppercase; color:var(--text-dim); margin-bottom:4px; }
.balance-amount { font-family:'Syne',sans-serif; font-size:36px; font-weight:800; color:var(--text); letter-spacing:-0.02em; }
.balance-amount.tight { color:var(--amber); }
.balance-amount.critical { color:var(--red); }
.balance-sub { font-size:12px; color:var(--text-dim); margin-top:4px; }

.finance-row { display:flex; justify-content:space-between; align-items:center; padding:9px 0; border-bottom:1px solid var(--border); }
.finance-row:last-child { border-bottom:none; }
.finance-row-label { font-size:13px; color:var(--text-mid); }
.finance-row-label.income { color:var(--accent); font-weight:500; }
.finance-row-value { font-size:13px; font-weight:600; color:var(--text); }
.finance-row-value.positive { color:var(--accent); }
.finance-row-value.negative { color:var(--red); }

.month-selector { display:flex; align-items:center; justify-content:center; gap:16px; margin-bottom:14px; }
.month-btn { background:none; border:1px solid var(--border); border-radius:8px; width:28px; height:28px; cursor:pointer; font-size:14px; color:var(--text-mid); display:flex; align-items:center; justify-content:center; }
.month-label { font-family:'Syne',sans-serif; font-size:13px; font-weight:700; color:var(--text); min-width:120px; text-align:center; }

/* Budget bars */
.budget-item { margin-bottom:14px; }
.budget-item:last-child { margin-bottom:0; }
.budget-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:5px; }
.budget-cat { font-size:12px; font-weight:500; color:var(--text); }
.budget-amounts { font-size:11px; color:var(--text-dim); }
.budget-bar-bg { height:6px; background:var(--surface2); border-radius:3px; overflow:hidden; }
.budget-bar-fill { height:100%; border-radius:3px; transition:width 0.5s ease; }
.fill-ok { background:var(--accent); }
.fill-warn { background:var(--amber); }
.fill-over { background:var(--red); }

/* Subscriptions */
.sub-item { display:flex; align-items:center; justify-content:space-between; padding:9px 0; border-bottom:1px solid var(--border); }
.sub-item:last-child { border-bottom:none; }
.sub-name { font-size:13px; color:var(--text); }
.sub-freq { font-size:11px; color:var(--text-dim); margin-top:1px; }
.sub-amount { font-size:13px; font-weight:600; color:var(--text); }
.sub-flag { font-size:10px; font-weight:600; padding:1px 6px; border-radius:20px; margin-left:6px; }
.flag-ok { background:var(--accent-glow); color:var(--accent); }
.flag-warn { background:var(--amber-glow); color:var(--amber); }
.sub-total { display:flex; justify-content:space-between; padding:10px 0 0; border-top:1px solid var(--border); margin-top:4px; }
.sub-total-label { font-size:12px; font-weight:600; color:var(--text-mid); }
.sub-total-val { font-family:'Syne',sans-serif; font-size:16px; font-weight:800; color:var(--text); }

/* ── SECTION 4: PORTFOLIO ── */
.portfolio-tabs { display:flex; border-bottom:1px solid var(--border); }
.portfolio-tab { flex:1; padding:9px 4px; font-size:10px; font-weight:600; letter-spacing:0.06em; text-transform:uppercase; color:var(--text-dim); background:none; border:none; cursor:pointer; border-bottom:2px solid transparent; transition:all 0.2s; margin-bottom:-1px; }
.portfolio-tab.active { color:var(--accent); border-bottom-color:var(--accent); }
.portfolio-panel { display:none; padding:14px 16px 16px; }
.portfolio-panel.active { display:block; }

.net-worth-hero { text-align:center; padding:10px 0 14px; border-bottom:1px solid var(--border); margin-bottom:14px; }
.net-worth-label { font-size:10px; font-weight:500; letter-spacing:0.2em; text-transform:uppercase; color:var(--text-dim); margin-bottom:4px; }
.net-worth-amount { font-family:'Syne',sans-serif; font-size:32px; font-weight:800; color:var(--accent); letter-spacing:-0.02em; }
.net-worth-sub { font-size:11px; color:var(--text-dim); margin-top:3px; }

.asset-item { display:flex; align-items:center; gap:12px; padding:10px 0; border-bottom:1px solid var(--border); }
.asset-item:last-child { border-bottom:none; }
.asset-icon { width:32px; height:32px; border-radius:8px; background:var(--accent-glow); display:flex; align-items:center; justify-content:center; font-size:14px; flex-shrink:0; }
.asset-info { flex:1; }
.asset-name { font-size:13px; font-weight:500; color:var(--text); }
.asset-detail { font-size:11px; color:var(--text-dim); margin-top:1px; }
.asset-value { text-align:right; }
.asset-eur { font-size:14px; font-weight:700; color:var(--text); }
.asset-change { font-size:11px; margin-top:1px; }
.change-pos { color:var(--accent); }
.change-neg { color:var(--red); }
.asset-loading { font-size:12px; color:var(--text-dim); font-style:italic; }

/* Staking */
.staking-item { background:var(--surface2); border-radius:10px; padding:12px; margin-bottom:10px; border:1px solid var(--border); }
.staking-item:last-child { margin-bottom:0; }
.staking-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:8px; }
.staking-name { font-size:13px; font-weight:600; color:var(--text); }
.staking-countdown { font-family:'Syne',sans-serif; font-size:16px; font-weight:800; }
.staking-countdown.urgent { color:var(--red); }
.staking-countdown.soon { color:var(--amber); }
.staking-countdown.ok { color:var(--accent); }
.staking-detail { font-size:11px; color:var(--text-dim); line-height:1.5; }
.staking-push-btn { margin-top:8px; font-size:10px; font-weight:600; color:var(--accent); background:var(--accent-glow); border:none; border-radius:6px; padding:4px 10px; cursor:pointer; }

/* Investment engine */
.investment-content { font-size:13px; color:var(--text-mid); line-height:1.75; }
.investment-content h4 { font-family:'Syne',sans-serif; font-size:12px; font-weight:800; color:var(--text); letter-spacing:0.05em; text-transform:uppercase; margin:14px 0 6px; }
.investment-content h4:first-child { margin-top:0; }
.investment-meta { font-size:11px; color:var(--text-dim); margin-top:12px; font-style:italic; }
.refresh-btn { display:flex; align-items:center; gap:6px; background:none; border:none; cursor:pointer; font-size:10px; font-weight:600; letter-spacing:0.15em; text-transform:uppercase; color:var(--accent); padding:0; opacity:0.7; transition:opacity 0.2s; margin-top:14px; }
.refresh-btn:hover { opacity:1; }
.refresh-btn.spinning svg { animation:spin 1s linear infinite; }
@keyframes spin { from{transform:rotate(0deg);}to{transform:rotate(360deg);} }

/* ── SECTION 5: DOCUMENT VAULT ── */
.pin-gate { padding:24px 20px; text-align:center; }
.pin-gate-title { font-family:'Syne',sans-serif; font-size:16px; font-weight:800; color:var(--text); margin-bottom:6px; }
.pin-gate-sub { font-size:13px; color:var(--text-dim); margin-bottom:20px; line-height:1.5; }
.pin-display { display:flex; justify-content:center; gap:10px; margin-bottom:20px; }
.pin-dot { width:14px; height:14px; border-radius:50%; background:var(--surface3); border:2px solid var(--border-strong); transition:background 0.15s; }
.pin-dot.filled { background:var(--accent); border-color:var(--accent); }
.pin-keypad { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; max-width:220px; margin:0 auto; }
.pin-key { padding:14px; background:var(--surface2); border:1px solid var(--border); border-radius:10px; font-family:'Syne',sans-serif; font-size:18px; font-weight:700; color:var(--text); cursor:pointer; transition:all 0.15s; }
.pin-key:active { background:var(--accent-glow); border-color:var(--accent); }
.pin-key.del { font-size:14px; color:var(--text-dim); }
.pin-error { font-size:12px; color:var(--red); margin-top:12px; height:16px; }
.pin-hint { font-size:11px; color:var(--text-dim); margin-top:12px; }

.vault-content { padding:14px 16px 16px; }
.vault-doc { background:var(--surface2); border-radius:10px; padding:12px; margin-bottom:10px; border:1px solid var(--border); }
.vault-doc:last-child { margin-bottom:0; }
.vault-doc-header { display:flex; justify-content:space-between; align-items:flex-start; gap:8px; }
.vault-doc-name { font-size:13px; font-weight:600; color:var(--text); }
.vault-doc-status { font-size:10px; font-weight:700; padding:2px 7px; border-radius:20px; flex-shrink:0; }
.status-urgent { background:var(--red-glow); color:var(--red); }
.status-soon { background:var(--amber-glow); color:var(--amber); }
.status-ok { background:var(--accent-glow); color:var(--accent); }
.status-expired { background:rgba(0,0,0,0.08); color:var(--text-dim); }
.vault-doc-detail { font-size:12px; color:var(--text-dim); margin-top:5px; line-height:1.5; }
.vault-doc-action { font-size:11px; font-weight:600; color:var(--accent); margin-top:6px; cursor:pointer; background:none; border:none; padding:0; display:inline; }

/* SHIMMER */
.shimmer { height:12px; border-radius:6px; background:linear-gradient(90deg,var(--surface2) 25%,#e8e8e4 50%,var(--surface2) 75%); background-size:200% 100%; animation:shim 1.4s infinite; margin-bottom:8px; }
.shimmer:nth-child(2){width:72%;animation-delay:0.1s;}
.shimmer:nth-child(3){width:52%;animation-delay:0.2s;}
@keyframes shim{0%{background-position:200% center;}100%{background-position:-200% center;}}

/* FOOTER */
.footer { padding:28px 20px 10px; display:flex; align-items:center; justify-content:center; gap:10px; }
.footer-line { width:20px; height:1px; background:var(--accent); opacity:0.2; }
.footer-text { font-size:10px; font-weight:500; letter-spacing:0.3em; text-transform:uppercase; color:var(--text-dim); }

.empty-note { font-size:13px; font-style:italic; color:var(--text-dim); text-align:center; padding:12px 0; }
.action-btn { padding:10px 16px; background:var(--accent); border:none; border-radius:8px; font-family:'DM Sans',sans-serif; font-size:12px; font-weight:600; color:#fff; cursor:pointer; transition:opacity 0.2s; }
.action-btn:hover { opacity:0.88; }
.action-btn.secondary { background:var(--surface2); border:1px solid var(--border); color:var(--text-mid); }
</style>
</head>
<body>
<div class="app">

  <div class="header">
    <a class="back-btn" href="index.html">←</a>
    <div class="header-text">
      <div class="header-eyebrow">Mon Monde</div>
      <div class="header-title">Admin & Finance</div>
    </div>
  </div>

  <div class="sections">

    <!-- ── SECTION 1: ADMIN TO-DO & DEADLINES ── -->
    <div class="card">
      <div class="card-header" onclick="toggle('deadlines')">
        <div class="card-header-left">
          <div class="card-icon">📋</div>
          <div class="card-title">Admin To-Do & Deadlines <span class="card-badge" id="deadline-badge"></span></div>
        </div>
        <div class="card-chevron open" id="chev-deadlines">▾</div>
      </div>
      <div class="card-collapse open" id="col-deadlines">
        <div class="deadline-tabs">
          <button class="deadline-tab active" id="dtab-upcoming" onclick="switchDeadlineTab('upcoming')">Upcoming</button>
          <button class="deadline-tab" id="dtab-done" onclick="switchDeadlineTab('done')">Done</button>
        </div>
        <div class="deadline-list" id="deadline-list"></div>
        <div class="deadline-add-form">
          <div class="deadline-input-row">
            <input class="deadline-input" id="deadline-text" type="text" placeholder="Add a task or deadline..."/>
            <button class="deadline-add-btn" onclick="addDeadline()">+</button>
          </div>
          <div class="deadline-date-row">
            <input class="deadline-date-input" id="deadline-date" type="date"/>
            <input class="deadline-date-input" id="deadline-cat" type="text" placeholder="Category (tax, rental, health…)" style="flex:2"/>
          </div>
        </div>
      </div>
    </div>

    <!-- ── SECTION 2: EMAIL TRIAGE ── -->
    <div class="card">
      <div class="card-header" onclick="toggle('emails')">
        <div class="card-header-left">
          <div class="card-icon">✉️</div>
          <div class="card-title">Email Triage</div>
        </div>
        <div class="card-chevron" id="chev-emails">▾</div>
